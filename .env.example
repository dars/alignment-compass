# 複製為 .env 並填入實際位置（.env 不進版控）
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=qwen3:8b
# 測驗 token 加密密鑰（正式環境必設，隨便一串長隨機字串即可）
#SESSION_SECRET=
# Cloudflare Access Service Token（若 Ollama tunnel 有加 Access 保護）
#CF_ACCESS_CLIENT_ID=
#CF_ACCESS_CLIENT_SECRET=
# 題目池（Upstash Redis REST；未設定則一律現場生成）
#KV_REST_API_URL=
#KV_REST_API_TOKEN=
#POOL_TARGET=40
# 每題可被使用的次數，用滿棄置換新題
#POOL_MAX_USES=3
# 補池端點金鑰（/api/refill?key=...；未設定則端點停用）
#REFILL_KEY=
